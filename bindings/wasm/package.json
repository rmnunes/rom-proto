{
  "name": "@rmnunes/rom",
  "version": "1.2.2",
  "description": "ROM SDK — Replicated Object Memory for TypeScript/WASM. Stream CRDT state across peers with adaptive routing and multi-resolution propagation.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "wasm/"
  ],
  "keywords": [
    "crdt",
    "state-replication",
    "mesh-networking",
    "peer-to-peer",
    "wasm",
    "real-time",
    "hebbian-routing",
    "conflict-free"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rmnunes/rom-proto",
    "directory": "bindings/wasm"
  },
  "scripts": {
    "build:wasm": "mkdir -p build && cd build && emcmake cmake .. && emmake make -j",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "devDependencies": {
    "typescript": "^5.0",
    "@types/node": "^20",
    "jest": "^29",
    "@jest/globals": "^29",
    "ts-jest": "^29"
  },
  "license": "MIT"
}
